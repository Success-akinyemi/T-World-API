{
  "info": {
    "name": "T-World Mini API",
    "description": "Postman collection for the T-World Mini API — Learning + Profiles",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"Secret1234\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"Secret1234\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Items",
      "item": [
        {
          "name": "List Items",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/items?page=1&limit=10" }
          }
        },
        {
          "name": "List Items – Filter by Category",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/items?category=course&level=beginner" }
          }
        },
        {
          "name": "Get Item by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/items/:id", "variable": [{ "key": "id", "value": "PASTE_ITEM_ID_HERE" }] }
          }
        },
        {
          "name": "Save Item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/items/:id/save", "variable": [{ "key": "id", "value": "PASTE_ITEM_ID_HERE" }] }
          }
        },
        {
          "name": "Unsave Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/items/:id/save", "variable": [{ "key": "id", "value": "PASTE_ITEM_ID_HERE" }] }
          }
        }
      ]
    },
    {
      "name": "Me",
      "item": [
        {
          "name": "Get Saved Items",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/me/saved" }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:5000/health" }
          }
        }
      ]
    }
  ]
}
